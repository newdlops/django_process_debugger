{
  "name": "django-process-debugger",
  "displayName": "Django Process Debugger",
  "description": "Attach debugpy to a running Django process for runtime debugging without modifying your codebase",
  "version": "0.1.0",
  "publisher": "newdlops",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/django-process-debugger"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "django",
    "python",
    "debugger",
    "debugpy",
    "attach",
    "macos",
    "apple-silicon"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "django-process",
        "label": "Django Process Debugger"
      }
    ],
    "configuration": {
      "title": "Django Process Debugger",
      "properties": {
        "djangoProcessDebugger.justMyCode": {
          "type": "boolean",
          "default": true,
          "description": "When true, the debugger only steps through your code. When false, it also steps into library/framework code (e.g., Django, Celery internals)."
        }
      }
    },
    "commands": [
      {
        "command": "djangoProcessDebugger.setup",
        "title": "Django Debugger: Setup"
      },
      {
        "command": "djangoProcessDebugger.teardown",
        "title": "Django Debugger: Remove Debug Support"
      },
      {
        "command": "djangoProcessDebugger.findDjangoProcesses",
        "title": "Django Debugger: Find Django Processes"
      },
      {
        "command": "djangoProcessDebugger.attachToProcess",
        "title": "Django Debugger: Attach to Django Process"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
