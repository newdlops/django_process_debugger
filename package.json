{
  "name": "django-process-debugger",
  "displayName": "Django Process Debugger",
  "description": "Attach debugpy to a running Django/Celery process for runtime debugging without modifying your codebase",
  "version": "0.2.1",
  "publisher": "newdlops",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0C4B33",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/newdlops/django_process_debugger"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "django",
    "python",
    "debugger",
    "debugpy",
    "attach",
    "celery",
    "macos",
    "apple-silicon"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "django-process",
        "label": "Django Process Debugger",
        "configurationAttributes": {
          "attach": {
            "properties": {
              "host": {
                "type": "string",
                "default": "127.0.0.1",
                "description": "Host address of the debugpy server"
              },
              "port": {
                "type": "number",
                "default": 5678,
                "description": "Port of the debugpy server"
              },
              "justMyCode": {
                "type": "boolean",
                "default": true,
                "description": "Only debug user-written code"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Django Process Debugger: Attach",
            "description": "Attach to a running Django/Celery process",
            "body": {
              "type": "django-process",
              "request": "attach",
              "name": "Attach to Django Process",
              "host": "127.0.0.1",
              "port": 5678,
              "justMyCode": true
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Django Process Debugger",
      "properties": {
        "djangoProcessDebugger.justMyCode": {
          "type": "boolean",
          "default": true,
          "description": "When true, the debugger only steps through your code. When false, it also steps into library/framework code (e.g., Django, Celery internals)."
        }
      }
    },
    "commands": [
      {
        "command": "djangoProcessDebugger.setup",
        "title": "Django Debugger: Setup"
      },
      {
        "command": "djangoProcessDebugger.attachToProcess",
        "title": "Django Debugger: Attach to Django Process"
      },
      {
        "command": "djangoProcessDebugger.killProcess",
        "title": "Django Debugger: Kill Django/Celery Process"
      },
      {
        "command": "djangoProcessDebugger.reinstallDebugpy",
        "title": "Django Debugger: Reinstall debugpy"
      },
      {
        "command": "djangoProcessDebugger.cleanPythonLanguageServer",
        "title": "Django Debugger: Clean All (Remove Bootstrap & Restore Python)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
